# ⚠️ 이 파일을 절대 GitHub에 올리지 마세요!
# .gitignore에 .env가 포함되어 있어 자동으로 제외됩니다

# =============================================
# Supabase 데이터베이스 (필수)
# Supabase Dashboard → Settings → Database → URI
# =============================================
DATABASE_URL="postgresql://postgres.여기에프로젝트ID:여기에비밀번호@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres"

# =============================================
# NextAuth 설정 (필수)
# =============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="여기에랜덤문자열입력"

# =============================================
# Google OAuth (선택 - 소셜 로그인)
# https://console.cloud.google.com
# =============================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# =============================================
# Kakao OAuth (선택 - 소셜 로그인)
# https://developers.kakao.com
# =============================================
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# =============================================
# OpenAI API (선택 - AI 분석 기능)
# https://platform.openai.com/api-keys
# =============================================
OPENAI_API_KEY=""
